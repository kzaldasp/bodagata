---
// src/components/Timeline.astro
---

<section class="py-20 md:py-32 px-6 md:px-12 bg-[#fafaf9] text-center">
    
    <p class="font-sans text-[10px] md:text-xs tracking-[0.3em] text-[#6b7c6d] uppercase mb-4 font-medium">
        El gran día
    </p>
    <h2 class="font-script text-6xl md:text-7xl text-[#4a594c] mb-16 drop-shadow-sm">
        Itinerario
    </h2>

    <div class="max-w-2xl mx-auto relative">
        
        <div class="absolute left-6 md:left-1/2 top-4 bottom-4 w-px bg-gradient-to-b from-transparent via-[#c4d1c6] to-transparent md:-translate-x-1/2"></div>

        <div class="space-y-12">
            
            <div class="relative flex flex-col md:flex-row items-start md:items-center text-left md:text-right group">
                <div class="md:w-1/2 md:pr-12 pl-16 md:pl-0">
                    <p class="font-sans text-sm md:text-base text-[#8b9b8d] font-semibold tracking-widest uppercase mb-1">12:30 PM - 1:30 PM</p>
                    <h3 class="font-serif text-2xl md:text-3xl text-[#4a594c]">Recibimiento & Cóctel</h3>
                    <p class="font-sans text-xs text-gray-500 mt-2 leading-relaxed max-w-sm ml-auto">Llegada de invitados y cóctel de bienvenida para empezar la celebración.</p>
                </div>
                <div class="absolute left-[20px] md:left-1/2 w-3 h-3 bg-[#4a594c] rounded-full md:-translate-x-1/2 mt-1.5 md:mt-0 ring-4 ring-white shadow-sm transition-transform duration-300 group-hover:scale-150 group-hover:bg-[#8b9b8d]"></div>
                <div class="md:w-1/2 hidden md:block"></div>
            </div>

            <div class="relative flex flex-col md:flex-row items-start md:items-center text-left group">
                <div class="md:w-1/2 hidden md:block"></div>
                <div class="absolute left-[20px] md:left-1/2 w-3 h-3 bg-[#4a594c] rounded-full md:-translate-x-1/2 mt-1.5 md:mt-0 ring-4 ring-white shadow-sm transition-transform duration-300 group-hover:scale-150 group-hover:bg-[#8b9b8d]"></div>
                <div class="md:w-1/2 pl-16 md:pl-12">
                    <p class="font-sans text-sm md:text-base text-[#8b9b8d] font-semibold tracking-widest uppercase mb-1">2:00 PM</p>
                    <h3 class="font-serif text-2xl md:text-3xl text-[#4a594c]">Ceremonia Civil y Oración</h3>
                </div>
            </div>

            <div class="relative flex flex-col md:flex-row items-start md:items-center text-left md:text-right group">
                <div class="md:w-1/2 md:pr-12 pl-16 md:pl-0">
                    <p class="font-sans text-sm md:text-base text-[#8b9b8d] font-semibold tracking-widest uppercase mb-1">2:30 PM</p>
                    <h3 class="font-serif text-2xl md:text-3xl text-[#4a594c]">Brindis y Bienvenida</h3>
                </div>
                <div class="absolute left-[20px] md:left-1/2 w-3 h-3 bg-[#4a594c] rounded-full md:-translate-x-1/2 mt-1.5 md:mt-0 ring-4 ring-white shadow-sm transition-transform duration-300 group-hover:scale-150 group-hover:bg-[#8b9b8d]"></div>
                <div class="md:w-1/2 hidden md:block"></div>
            </div>

            <div class="relative flex flex-col md:flex-row items-start md:items-center text-left group">
                <div class="md:w-1/2 hidden md:block"></div>
                <div class="absolute left-[20px] md:left-1/2 w-3 h-3 bg-[#4a594c] rounded-full md:-translate-x-1/2 mt-1.5 md:mt-0 ring-4 ring-white shadow-sm transition-transform duration-300 group-hover:scale-150 group-hover:bg-[#8b9b8d]"></div>
                <div class="md:w-1/2 pl-16 md:pl-12">
                    <p class="font-sans text-sm md:text-base text-[#8b9b8d] font-semibold tracking-widest uppercase mb-1">2:40 PM - 3:30 PM</p>
                    <h3 class="font-serif text-2xl md:text-3xl text-[#4a594c]">Actividades</h3>
                </div>
            </div>

            <div class="relative flex flex-col md:flex-row items-start md:items-center text-left md:text-right group">
                <div class="md:w-1/2 md:pr-12 pl-16 md:pl-0">
                    <p class="font-sans text-sm md:text-base text-[#8b9b8d] font-semibold tracking-widest uppercase mb-1">3:45 PM - 4:45 PM</p>
                    <h3 class="font-serif text-2xl md:text-3xl text-[#4a594c]">Comida</h3>
                    <p class="font-sans text-xs text-gray-500 mt-2 leading-relaxed max-w-sm ml-auto">Disfrutemos juntos de un delicioso banquete.</p>
                </div>
                <div class="absolute left-[20px] md:left-1/2 w-3 h-3 bg-[#4a594c] rounded-full md:-translate-x-1/2 mt-1.5 md:mt-0 ring-4 ring-white shadow-sm transition-transform duration-300 group-hover:scale-150 group-hover:bg-[#8b9b8d]"></div>
                <div class="md:w-1/2 hidden md:block"></div>
            </div>

        </div>
    </div>
</section>