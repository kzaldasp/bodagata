---
// src/components/DressCode.astro
import { Icon } from 'astro-icon/components';
---

<section class="py-20 md:py-28 px-6 text-center bg-white">
    <div class="max-w-2xl mx-auto flex flex-col items-center">
        
        <div class="w-16 h-16 bg-[#f4f6f3] rounded-full flex items-center justify-center shadow-sm mb-6 border border-[#e3e9e3]">
            <Icon name="ph:coat-hanger-light" class="w-8 h-8 text-[#8b9b8d]" />
        </div>
        
        <h2 class="font-script text-5xl md:text-6xl text-[#4a594c] mb-6 drop-shadow-sm">
            Dress Code
        </h2>
        
        <p class="font-sans text-xl md:text-2xl tracking-[0.2em] font-semibold text-[#8b9b8d] uppercase mb-6">
            Formal
        </p>
        
        <p class="font-serif text-lg md:text-xl text-gray-600 leading-relaxed">
            Con mucho cariño, les recordamos que el color blanco y tonos similares están reservados exclusivamente para la novia.
        </p>
        
    </div>
</section>