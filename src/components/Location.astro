---
// src/components/Location.astro
import { Icon } from 'astro-icon/components';
---

<section class="py-20 md:py-32 px-6 md:px-12 bg-white text-center">
    
    <p class="font-sans text-[10px] md:text-xs tracking-[0.3em] text-[#6b7c6d] uppercase mb-4 font-medium">
        Dónde celebrar
    </p>
    <h2 class="font-script text-6xl md:text-7xl text-[#4a594c] mb-16 drop-shadow-sm">
        Ubicación
    </h2>

    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12 md:gap-20">
        
        <div class="w-full md:w-1/2 h-72 md:h-[28rem] rounded-2xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.08)] transform transition-transform duration-700 hover:scale-[1.02]">
            <iframe 
                src="https://maps.google.com/maps?q=Qhawana+Aventura,+Puembo,+Quito&t=&z=15&ie=UTF8&iwloc=&output=embed" 
                width="100%" 
                height="100%" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade"
                class="w-full h-full grayscale-[20%] contrast-[90%]"> </iframe>
        </div>

        <div class="w-full md:w-1/2 text-center md:text-left flex flex-col items-center md:items-start">
            <Icon name="ph:map-pin-light" class="w-12 h-12 text-[#8b9b8d] mb-6" />
            
            <h3 class="font-serif text-3xl md:text-5xl text-[#4a594c] mb-4">Qhawana Aventura</h3>
            <p class="font-sans text-sm md:text-base text-gray-500 leading-relaxed mb-10 max-w-sm">
                La Rabija y 24 de Mayo.<br>Puembo, Quito
            </p>

            <a href="https://maps.google.com/maps?q=Qhawana+Aventura,+Puembo,+Quito" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 border border-[#8b9b8d] text-[#4a594c] font-sans text-xs md:text-sm tracking-widest uppercase py-4 px-8 rounded-full hover:bg-[#8b9b8d] hover:text-white transition-all duration-300">
                <Icon name="ph:map-trifold-light" class="w-5 h-5" />
                Llegar con Google Maps
            </a>
        </div>

    </div>
</section>