---
// src/components/Gallery.astro
---

<section class="py-20 md:py-32 px-6 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto text-center">
        
        <p class="font-sans text-[10px] md:text-xs tracking-[0.3em] text-[#6b7c6d] uppercase mb-4 font-medium">
            Capturando el amor
        </p>
        <h2 class="font-script text-6xl md:text-7xl text-[#4a594c] mb-16 drop-shadow-sm">
            Nuestros Momentos
        </h2>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-6 auto-rows-[150px] md:auto-rows-[250px]">
            
            <div class="col-span-1 row-span-2 overflow-hidden rounded-xl shadow-sm group">
                <img src="https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=800&q=80" alt="Momento 1" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" loading="lazy" />
            </div>

            <div class="col-span-1 row-span-1 overflow-hidden rounded-xl shadow-sm group">
                <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?auto=format&fit=crop&w=800&q=80" alt="Momento 2" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" loading="lazy" />
            </div>

            <div class="col-span-2 row-span-1 overflow-hidden rounded-xl shadow-sm group">
                <img src="https://images.unsplash.com/photo-1606800052052-a08af7148866?auto=format&fit=crop&w=1200&q=80" alt="Momento 3" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" loading="lazy" />
            </div>

            <div class="col-span-1 row-span-1 overflow-hidden rounded-xl shadow-sm group">
                <img src="https://images.unsplash.com/photo-1520854221256-17451cc331bf?auto=format&fit=crop&w=800&q=80" alt="Momento 4" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" loading="lazy" />
            </div>

            <div class="col-span-1 md:col-span-2 row-span-2 md:row-span-1 overflow-hidden rounded-xl shadow-sm group">
                <img src="https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=1200&q=80" alt="Momento 5" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" loading="lazy" />
            </div>

            <div class="col-span-1 row-span-1 overflow-hidden rounded-xl shadow-sm group">
                <img src="https://images.unsplash.com/photo-1537274942065-eda9d00a6293?auto=format&fit=crop&w=800&q=80" alt="Momento 6" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" loading="lazy" />
            </div>
            
        </div>
    </div>
</section>