---
// src/components/Gallery.astro
import { Image } from 'astro:assets';

const imageFiles = import.meta.glob<{ default: ImageMetadata }>('/src/assets/gallery/*.{jpeg,jpg,png,webp}');

// Procesamos y ORDENAMOS las imágenes alfabéticamente/numéricamente por su ruta
const images = await Promise.all(
    Object.keys(imageFiles)
        .sort((a, b) => a.localeCompare(b, undefined, { numeric: true })) // <-- Esta línea hace la magia del orden
        .map((path) => imageFiles[path]())
);
---

<section class="py-20 md:py-32 px-6 bg-white overflow-hidden">
...


<section class="py-20 md:py-32 px-6 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto text-center">
        
        <p class="font-sans text-[10px] md:text-xs tracking-[0.3em] text-[#6b7c6d] uppercase mb-4 font-medium">
            Capturando el amor
        </p>
        <h2 class="font-script text-6xl md:text-7xl text-[#4a594c] mb-16 drop-shadow-sm">
            Nuestros Momentos
        </h2>

        <div class="columns-2 md:columns-3 lg:columns-4 gap-3 md:gap-6 space-y-3 md:space-y-6">
            
            {images.map((img, index) => (
                <div class="break-inside-avoid overflow-hidden rounded-xl shadow-sm group">
                    <Image 
                        src={img.default} 
                        alt={`Momento ${index + 1}`} 
                        quality="high"
                        class="w-full h-auto object-cover transition-transform duration-1000 group-hover:scale-110" 
                    />
                </div>
            ))}

        </div>
    </div>
</section>