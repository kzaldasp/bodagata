// src/components/Verse.astro
---

<section class="py-16 md:py-24 px-8 text-center bg-[#f2f4f1] relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-px bg-[#c4d1c6]"></div>
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-px bg-[#c4d1c6]"></div>

    <svg class="w-8 h-8 mx-auto text-[#8b9b8d] mb-6 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
    </svg>

    <blockquote class="font-serif text-2xl md:text-3xl lg:text-4xl text-[#4a594c] italic max-w-3xl mx-auto leading-relaxed md:leading-loose">
        "Y sobre todas estas cosas vestíos de amor, que es el vínculo perfecto."
    </blockquote>
    
    <p class="font-sans text-[10px] md:text-xs text-gray-500 mt-8 uppercase tracking-[0.3em] font-medium">
        Colosenses 3:14
    </p>
</section>