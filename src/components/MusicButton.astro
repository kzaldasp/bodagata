---
// src/components/MusicButton.astro
---

<div class="fixed bottom-6 right-6 md:bottom-10 md:right-10 z-50">
	<button id="music-toggle" class="bg-[#8b9b8d] text-white w-14 h-14 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.15)] flex items-center justify-center hover:scale-105 transition-all duration-300 animate-bounce cursor-pointer border-2 border-white">
		<svg id="music-icon" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
			<path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
		</svg>
	</button>
	<audio id="bg-audio" loop>
		<source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
	</audio>
</div>

<script>
	const audio = document.getElementById('bg-audio') as HTMLAudioElement;
	const musicBtn = document.getElementById('music-toggle');
	
	let isPlaying = false;

	musicBtn?.addEventListener('click', () => {
		if (isPlaying) {
			audio.pause();
			musicBtn.classList.remove('animate-[spin_4s_linear_infinite]');
			musicBtn.classList.add('animate-bounce');
		} else {
			audio.play();
			musicBtn.classList.remove('animate-bounce');
			musicBtn.classList.add('animate-[spin_4s_linear_infinite]'); 
		}
		isPlaying = !isPlaying;
	});
</script>