---
// src/components/RSVP.astro
import { Icon } from 'astro-icon/components';

const whatsappNumber = "593984205259";

// Mensaje para confirmar (Botón Principal)
const confirmMessage = encodeURI("¡Hola! Quiero confirmar mi asistencia a la boda de José David y Jenny Elizabeth. 🤍");
const confirmLink = `https://wa.me/${whatsappNumber}?text=${confirmMessage}`;

// Mensaje para declinar elegantemente (Botón Secundario)
const declineMessage = encodeURI("¡Hola! Agradezco muchísimo la invitación a su boda. Lamentablemente no podré acompañarlos físicamente, pero les envío mis mejores deseos en esta nueva etapa. ¡Muchas felicidades a José David y Jenny Elizabeth! ✨");
const declineLink = `https://wa.me/${whatsappNumber}?text=${declineMessage}`;
---

<section class="py-24 md:py-32 px-6 text-center bg-[#f2f4f1]">
    <div class="max-w-3xl mx-auto">
        
        <Icon name="ph:envelope-open-light" class="w-12 h-12 mx-auto text-[#8b9b8d] mb-8" />
        
        <h2 class="font-script text-6xl md:text-8xl text-[#4a594c] mb-8 drop-shadow-sm">
            ¡Tenemos todo listo!
        </h2>
        
        <p class="font-serif text-xl md:text-2xl text-gray-600 mb-14 leading-relaxed">
            Nuestra felicidad solo estará completa si nos acompañas.<br class="hidden md:block"> Por favor, confirma tu asistencia.
        </p>

        <div class="flex flex-col md:flex-row items-center justify-center gap-5 md:gap-8">
            
            <a href={confirmLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-3 bg-[#4a594c] text-white font-sans text-sm md:text-base font-semibold tracking-widest uppercase py-5 px-10 rounded-full shadow-[0_10px_30px_rgba(74,89,76,0.2)] hover:bg-[#8b9b8d] hover:shadow-[0_10px_30px_rgba(139,155,141,0.4)] hover:-translate-y-1 transition-all duration-300 w-full md:w-auto">
                <Icon name="mdi:whatsapp" class="w-6 h-6 md:w-7 md:h-7" />
                Confirmar Asistencia
            </a>

            <a href={declineLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-3 border border-[#c4d1c6] text-[#6b7c6d] font-sans text-xs md:text-sm font-semibold tracking-widest uppercase py-4 px-8 rounded-full hover:border-[#8b9b8d] hover:text-[#4a594c] hover:bg-white transition-all duration-300 w-full md:w-auto">
                <Icon name="ph:hand-heart-light" class="w-5 h-5 md:w-6 md:h-6" />
                No podré asistir
            </a>

        </div>
        
    </div>
</section>